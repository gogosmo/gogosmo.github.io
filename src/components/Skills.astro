---
import Icon from './Icon.astro';

const { lang = 'en' } = Astro.props;

const content = {
	en: [
		{
			icon: 'terminal-window',
			title: 'Software Engineering',
			desc: 'Specialized in backend development, API design, and software architecture — from startups to large corporations.',
		},
		{
			icon: 'trophy',
			title: 'Data & AI',
			desc: "Master's degree in Data Engineering & AI. I turn raw data into actionable insights using Python, SQL, ETL pipelines, and machine learning models.",
		},
		{
			icon: 'strategy',
			title: 'Project Management',
			desc: '3+ years bridging technical and business teams. Experienced in agile methods, sprint planning, and delivering concrete solutions on time.',
		},
		{
			icon: 'rocket-launch',
			title: 'AI Automation',
			desc: 'Building intelligent workflows with n8n, Make, and AI agents (Claude, Gemini). From WhatsApp bots to automated data pipelines and Airtable dashboards.',
		},
	],
	fr: [
		{
			icon: 'terminal-window',
			title: 'Ingénierie Logicielle',
			desc: "Spécialisé dans le développement backend, la conception d'API et l'architecture logicielle — de la startup aux grandes entreprises.",
		},
		{
			icon: 'trophy',
			title: 'Data & IA',
			desc: "Master en Ingénierie Data & IA. Je transforme les données brutes en insights actionnables grâce à Python, SQL, des pipelines ETL et des modèles de machine learning.",
		},
		{
			icon: 'strategy',
			title: 'Gestion de projet',
			desc: "3+ ans à faire le lien entre équipes techniques et métier. Expérimenté en méthodes agiles, sprint planning et livraison de solutions concrètes dans les délais.",
		},
		{
			icon: 'rocket-launch',
			title: 'Automatisation IA',
			desc: "Construction de workflows intelligents avec n8n, Make et des agents IA (Claude, Gemini). Des bots WhatsApp aux pipelines de données automatisés et tableaux de bord Airtable.",
		},
	],
} as const;

const items = content[lang as keyof typeof content] ?? content.en;
---

<section class="box skills">
	{items.map((item) => (
		<div class="skill-item">
			<div class="skill-header">
				<Icon icon={item.icon as any} color="var(--accent-regular)" size="2.5rem" gradient />
				<h2>{item.title}</h2>
			</div>
			<p>{item.desc}</p>
		</div>
	))}
</section>

<script>
	const items = document.querySelectorAll<HTMLElement>('.skill-item');
	items.forEach(item => {
		item.style.opacity = '0';
		item.style.transform = 'translateY(24px)';
		item.style.transition = 'none';
	});

	const observer = new IntersectionObserver((entries) => {
		entries.forEach(entry => {
			if (entry.isIntersecting) {
				items.forEach((item, i) => {
					setTimeout(() => {
						item.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
						item.style.opacity = '1';
						item.style.transform = 'translateY(0)';
					}, i * 150);
				});
				observer.disconnect();
			}
		});
	}, { threshold: 0.15 });

	const section = document.querySelector('.skills');
	if (section) observer.observe(section);
</script>

<style>
	.box {
		border: 1px solid var(--gray-800);
		border-radius: 0.75rem;
		padding: 1.5rem;
		background-color: var(--gray-999_40);
		box-shadow: var(--shadow-sm);
	}

	.skills {
		display: flex;
		flex-direction: column;
		gap: 3rem;
	}

	.skill-item {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.skill-header {
		display: flex;
		align-items: center;
		gap: 0.75rem;
	}

	.skills h2 {
		font-size: var(--text-lg);
		margin: 0;
	}

	.skills p {
		color: var(--gray-400);
	}

	@media (min-width: 50em) {
		.box {
			border-radius: 1.5rem;
			padding: 2rem;
		}

		.skills {
			display: grid;
			grid-template-columns: repeat(2, 1fr);
			gap: 2rem 4rem;
		}

		.skills h2 {
			font-size: var(--text-lg);
		}
	}
</style>
