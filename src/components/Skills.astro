---
import Icon from './Icon.astro';
---

<section class="box skills">
	<div class="skill-item">
		<div class="skill-header">
			<Icon icon="terminal-window" color="var(--accent-regular)" size="2.5rem" gradient />
			<h2>Software Engineering</h2>
		</div>
		<p>Specialized in backend development, API design, and software architecture — from startups to large corporations.</p>
	</div>
	<div class="skill-item">
		<div class="skill-header">
			<Icon icon="trophy" color="var(--accent-regular)" size="2.5rem" gradient />
			<h2>Data & AI</h2>
		</div>
		<p>Master's degree in Data Engineering & AI. I turn raw data into actionable insights using Python, SQL, ETL pipelines, and machine learning models.</p>
	</div>
	<div class="skill-item">
		<div class="skill-header">
			<Icon icon="strategy" color="var(--accent-regular)" size="2.5rem" gradient />
			<h2>Project Management</h2>
		</div>
		<p>3+ years bridging technical and business teams. Experienced in agile methods, sprint planning, and delivering concrete solutions on time.</p>
	</div>
	<div class="skill-item">
		<div class="skill-header">
			<Icon icon="rocket-launch" color="var(--accent-regular)" size="2.5rem" gradient />
			<h2>AI Automation</h2>
		</div>
		<p>Building intelligent workflows with n8n, Make, and AI agents (Claude, Gemini). From WhatsApp bots to automated data pipelines and Airtable dashboards.</p>
	</div>
</section>

<script>
	const items = document.querySelectorAll<HTMLElement>('.skill-item');
	items.forEach(item => {
		item.style.opacity = '0';
		item.style.transform = 'translateY(24px)';
		item.style.transition = 'none';
	});

	const observer = new IntersectionObserver((entries) => {
		entries.forEach(entry => {
			if (entry.isIntersecting) {
				items.forEach((item, i) => {
					setTimeout(() => {
						item.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
						item.style.opacity = '1';
						item.style.transform = 'translateY(0)';
					}, i * 150);
				});
				observer.disconnect();
			}
		});
	}, { threshold: 0.15 });

	const section = document.querySelector('.skills');
	if (section) observer.observe(section);
</script>

<style>
	.box {
		border: 1px solid var(--gray-800);
		border-radius: 0.75rem;
		padding: 1.5rem;
		background-color: var(--gray-999_40);
		box-shadow: var(--shadow-sm);
	}

	.skills {
		display: flex;
		flex-direction: column;
		gap: 3rem;
	}

	.skill-item {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.skill-header {
		display: flex;
		align-items: center;
		gap: 0.75rem;
	}

	.skills h2 {
		font-size: var(--text-lg);
		margin: 0;
	}

	.skills p {
		color: var(--gray-400);
	}

	@media (min-width: 50em) {
		.box {
			border-radius: 1.5rem;
			padding: 2rem;
		}

		.skills {
			display: grid;
			grid-template-columns: repeat(2, 1fr);
			gap: 2rem 4rem;
		}

		.skills h2 {
			font-size: var(--text-lg);
		}
	}
</style>
