---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContactCTA from '../../components/ContactCTA.astro';
import Hero from '../../components/Hero.astro';
---

<BaseLayout title="À propos | Jughurta Gahlouz" description="À propos de Jughurta Gahlouz — Ingénieur Software & Data basé à Paris">
	<div class="stack gap-20">
		<main class="wrapper about">
			<Hero
				title="À propos"
				tagline="Ingénieur Software & Data passionné par l'IA, l'automatisation et la transformation des données en valeur métier concrète."
				align="center"
			/>

			<section>
				<h2 class="section-title">Parcours</h2>
				<div class="content">
					<p>
						Je suis titulaire d'un <a href="https://igm.univ-gustave-eiffel.fr/" target="_blank">Master en Ingénierie Software & Data</a> de l'Université Gustave Eiffel (IGM, Paris).
						Je me spécialise dans le développement backend, l'analyse de données et l'automatisation IA — animé par la passion de construire des systèmes qui fonctionnent réellement en production.
					</p>
					<p>
						Mon parcours m'a conduit dans des startups et de grandes entreprises, ce qui m'a donné à la fois une expertise technique et une compréhension des enjeux business. Aujourd'hui, je me concentre sur la création de workflows IA et de solutions data qui aident les équipes à travailler plus intelligemment.
					</p>
					<p>
						En dehors de l'ingénierie, j'explore de nouveaux outils d'automatisation, je contribue à des projets open-source et je partage mes apprentissages via des dépôts GitHub et des projets personnels.
					</p>
					<p>
						Retrouvez mes travaux et mon CV <a href="https://github.com/Gogo-IGM-BK" target="_blank">sur mon GitHub →</a>
					</p>
				</div>
			</section>

			<section>
				<h2 class="section-title">Expérience</h2>
				<div class="content experience-list">
					<div class="exp-item">
						<div class="exp-header">
							<span class="exp-role">Ingénieur Software & Data — Freelance</span>
						</div>
						<p>Création de workflows d'automatisation IA avec n8n, Claude, Gemini et l'API WhatsApp Business. Conception de pipelines de données, tableaux de bord Airtable et agents intelligents pour des clients professionnels.</p>
						<div class="exp-tags">
							<span class="exp-tag">n8n</span>
							<span class="exp-tag">Claude API</span>
							<span class="exp-tag">Gemini</span>
							<span class="exp-tag">Python</span>
							<span class="exp-tag">Airtable</span>
							<span class="exp-tag">Supabase</span>
							<span class="exp-tag">WhatsApp API</span>
						</div>
					</div>
					<div class="exp-item">
						<div class="exp-header">
							<span class="exp-role">Data Analyst — Iziwork</span>
						</div>
						<p>Processus ETL sur bases de données NoSQL, études de faisabilité et intégration de variables de modèles ML pour optimiser la précision du matching candidat-offre et évaluer l'impact financier des API externes.</p>
						<div class="exp-tags">
							<span class="exp-tag">Python</span>
							<span class="exp-tag">ETL</span>
							<span class="exp-tag">MongoDB</span>
							<span class="exp-tag">Machine Learning</span>
							<span class="exp-tag">Pandas</span>
							<span class="exp-tag">SQL</span>
						</div>
					</div>
					<div class="exp-item">
						<div class="exp-header">
							<span class="exp-role">Chef de projet IT & Développeur — McDonald's France</span>
						</div>
						<p>Conception et développement d'un outil interne de suivi et de gestion de projets, facilitant la planification et la synchronisation entre les parties prenantes techniques et métier.</p>
						<div class="exp-tags">
							<span class="exp-tag">JavaScript</span>
							<span class="exp-tag">REST API</span>
							<span class="exp-tag">Agile / Scrum</span>
							<span class="exp-tag">Git</span>
							<span class="exp-tag">Docker</span>
						</div>
					</div>
				</div>
			</section>

			<section>
				<h2 class="section-title">Formation</h2>
				<div class="content experience-list">
					<div class="exp-item">
						<div class="exp-header">
							<span class="exp-role">Master 2 — Data & Intelligence Artificielle</span>
						</div>
						<p>École IPSSI, Paris</p>
					</div>
					<div class="exp-item">
						<div class="exp-header">
							<span class="exp-role">Master 2 — Ingénierie Software & Data</span>
						</div>
						<p>Université Gustave Eiffel — Institut Gaspard-Monge (IGM), Paris</p>
					</div>
					<div class="exp-item">
						<div class="exp-header">
							<span class="exp-role">Licence — Mathématiques & Informatique</span>
						</div>
						<p>Université Gustave Eiffel — Institut Gaspard-Monge (IGM), Paris</p>
					</div>
				</div>
			</section>

			<section>
				<h2 class="section-title">Compétences</h2>
				<div class="content skills-grid">
					<div class="skill-group">
						<h5>Langages & Backend</h5>
						<ul>
							<li>Python · Java · JavaScript</li>
							<li>REST API · SQL · NoSQL</li>
							<li>Architecture Backend</li>
						</ul>
					</div>
					<div class="skill-group">
						<h5>Data & IA</h5>
						<ul>
							<li>ETL · Analyse de données</li>
							<li>Machine Learning · Pandas · NumPy</li>
							<li>Visualisation · Power BI</li>
						</ul>
					</div>
					<div class="skill-group">
						<h5>Automatisation IA</h5>
						<ul>
							<li>n8n · Make (Integromat)</li>
							<li>Claude · OpenAI · Gemini APIs</li>
							<li>WhatsApp Business · Airtable</li>
						</ul>
					</div>
					<div class="skill-group">
						<h5>Outils & Méthodes</h5>
						<ul>
							<li>Git · Docker · GitHub Actions</li>
							<li>Agile · Scrum</li>
							<li>Supabase · PostgreSQL · Kafka</li>
						</ul>
					</div>
				</div>
			</section>
		</main>

		<ContactCTA title="Intéressé par une collaboration ?" cta="Envoyer un message" />
	</div>
</BaseLayout>

<style>
	.about :global(.title) { font-size: var(--text-xl); }
	.about :global(.tagline) { font-size: var(--text-sm); color: var(--gray-300); text-align: center; }
	@media (min-width: 50em) { .about :global(.title) { font-size: var(--text-2xl); } }

	.about { display: flex; flex-direction: column; gap: 3.5rem; }
	section { display: flex; flex-direction: column; gap: 0.5rem; color: var(--gray-200); }
	.section-title { grid-column-start: 1; font-size: var(--text-xl); color: var(--gray-0); }
	.content { grid-column: 2 / 4; }
	.content :global(a) { text-decoration: 1px solid underline transparent; text-underline-offset: 0.25em; transition: text-decoration-color var(--theme-transition); }
	.content :global(a:hover), .content :global(a:focus) { text-decoration-color: currentColor; }
	.experience-list { display: flex; flex-direction: column; gap: 2rem; }
	.exp-item { border-left: 3px solid var(--accent-regular); padding-left: 1.25rem; }
	.exp-header { display: flex; flex-wrap: wrap; justify-content: space-between; align-items: baseline; gap: 0.5rem; margin-bottom: 0.4rem; }
	.exp-role { font-weight: 600; color: var(--gray-0); font-size: var(--text-md); }
	.exp-date { font-size: var(--text-sm); color: var(--accent-regular); font-weight: 600; }
	.exp-tags { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-top: 0.6rem; }
	.exp-tag { font-size: var(--text-xs, 0.75rem); padding: 0.2rem 0.6rem; border-radius: 99rem; border: 1px solid var(--accent-regular); color: #ffffff; background: color-mix(in srgb, var(--accent-dark) 50%, transparent); font-weight: 500; }
	.skills-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 2rem; }
	.skill-group h5 { color: var(--accent-regular); margin-bottom: 0.5rem; font-size: var(--text-base); text-transform: uppercase; letter-spacing: 0.05em; }
	.skill-group ul { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 0.3rem; }
	.skill-group li { color: var(--gray-300); font-size: var(--text-sm); }

	@media (min-width: 50em) {
		.about { display: grid; grid-template-columns: 1fr 60% 1fr; }
		.about > :global(:first-child) { grid-column-start: 2; }
		section { display: contents; font-size: var(--text-lg); }
		.skills-grid { grid-template-columns: repeat(2, 1fr); }
	}
</style>
