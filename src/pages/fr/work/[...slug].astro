---
import { type CollectionEntry, getCollection } from 'astro:content';

import BaseLayout from '../../../layouts/BaseLayout.astro';
import ContactCTA from '../../../components/ContactCTA.astro';
import Hero from '../../../components/Hero.astro';
import Pill from '../../../components/Pill.astro';

interface Props {
	entry: CollectionEntry<'work'>;
}

export async function getStaticPaths() {
	const work = await getCollection('work');
	return work.map((entry) => ({
		params: { slug: entry.slug },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const title = entry.data.title_fr ?? entry.data.title;
const description = entry.data.description_fr ?? entry.data.description;
---

<BaseLayout title={title} description={description}>
	<div class="stack gap-20">
		<div class="stack gap-15">
			<header>
				<div class="wrapper stack gap-2">
					<Hero title={title} align="center">
						<div class="details">
							<div class="tags">
								{entry.data.tags.map((t) => <Pill>{t}</Pill>)}
							</div>
							<p class="description">{description}</p>
						</div>
					</Hero>
				</div>
			</header>
			<main class="wrapper">
				<div class="stack gap-10 content">
					{entry.data.video
						? <video class="work-video" src={entry.data.video} autoplay loop muted playsinline />
						: entry.data.img && <img src={entry.data.img} alt={entry.data.img_alt || ''} />
					}
					<div class="content">
						<Content />
					</div>
				</div>
			</main>
		</div>
		<ContactCTA title="Intéressé par une collaboration ?" cta="Envoyer un message" />
	</div>
</BaseLayout>

<style>
	header { padding-top: 0; padding-bottom: 1.5rem; border-bottom: 1px solid var(--gray-800); }
	header :global(.title) { font-size: var(--text-xl); }
	@media (min-width: 50em) { header :global(.title) { font-size: var(--text-2xl); } }

	.details { display: flex; flex-direction: column; padding: 0.5rem; gap: 0.75rem; align-items: center; }
	.tags { display: flex; gap: 0.5rem; flex-wrap: wrap; justify-content: center; }
	.description { font-size: var(--text-sm); max-width: 54ch; text-align: center; color: var(--gray-300); }

	.content { max-width: 65ch; margin-inline: auto; }
	.content > :global(* + *) { margin-top: 1rem; }
	.content :global(h1) { font-size: var(--text-xl); margin: 1.5rem 0; }
	.content :global(h2) { font-size: var(--text-lg); margin: 1.5rem 0; }
	.content :global(h3), .content :global(h4), .content :global(h5) { font-size: var(--text-md); margin: 1.5rem 0; }
	.content :global(img) { border-radius: 1.5rem; box-shadow: var(--shadow-sm); background: var(--gradient-subtle); border: 1px solid var(--gray-800); }

	.work-video { border-radius: 1.5rem; box-shadow: var(--shadow-sm); border: 1px solid var(--gray-800); width: 100%; max-width: 480px; display: block; margin-inline: auto; aspect-ratio: 16 / 9; object-fit: cover; }

	.content :global(blockquote) { font-size: var(--text-base); font-family: var(--font-brand); font-weight: 400; font-style: italic; line-height: 1.4; padding-inline-start: 1.5rem; border-inline-start: 0.25rem solid var(--accent-dark); color: var(--gray-300); }
	.content :global(a) { text-decoration: 1px solid underline transparent; text-underline-offset: 0.25em; transition: text-decoration-color var(--theme-transition); }
	.content :global(a:hover), .content :global(a:focus) { text-decoration-color: currentColor; }

	.content :global(table) { width: 100%; border-collapse: collapse; font-size: var(--text-sm); }
	.content :global(th), .content :global(td) { padding: 0.5rem 0.75rem; border: 1px solid var(--gray-700); }
	.content :global(th) { background: var(--gray-800); color: var(--gray-0); }
	.content :global(pre) { border-radius: 0.75rem; padding: 1rem; overflow-x: auto; border: 1px solid var(--gray-700); }
</style>
