---
import { getCollection } from 'astro:content';

import BaseLayout from '../../layouts/BaseLayout.astro';
import CallToAction from '../../components/CallToAction.astro';
import Grid from '../../components/Grid.astro';
import Hero from '../../components/Hero.astro';
import Icon from '../../components/Icon.astro';
import Pill from '../../components/Pill.astro';
import PortfolioPreview from '../../components/PortfolioPreview.astro';
import ContactCTA from '../../components/ContactCTA.astro';
import Skills from '../../components/Skills.astro';

const allProjects = await getCollection('work');
const projects = allProjects.sort(() => Math.random() - 0.5).slice(0, 4);
---

<BaseLayout
	title="Jughurta Gahlouz — Ingénieur Software & Data"
	description="Ingénieur Software & Data spécialisé en automatisation IA, basé à Paris."
>
	<div class="stack gap-8 lg:gap-20">
		<div class="wrapper stack gap-8 lg:gap-20">
			<header class="hero">
				<Hero
					title="Bonjour, je suis Jughurta Gahlouz"
					tagline="Ingénieur Software & Data · Automatisation IA · Basé à Paris 🇫🇷"
					align="start"
				>
					<div class="roles">
						<Pill><Icon icon="code" size="1.33em" /> Développeur</Pill>
						<Pill><Icon icon="trophy" size="1.33em" /> Data & IA</Pill>
						<Pill><Icon icon="rocket-launch" size="1.33em" /> Automatisation IA</Pill>
						<Pill><Icon icon="strategy" size="1.33em" /> Chef de projet</Pill>
					</div>
				</Hero>

				<img alt="Jughurta Gahlouz" width="480" height="620" src="/assets/image_pro.jpg" />
			</header>

			<Skills lang="fr" />
		</div>

		<main class="wrapper stack gap-8 lg:gap-20">
			<section class="section tech-stack">
				<header class="section-header stack gap-2 lg:gap-4">
					<h3>Stack Technologique</h3>
					<p>Technologies que j'utilise pour construire, automatiser et analyser.</p>
				</header>
				<div class="tech-grid">
					<div class="tech-category">
						<div class="tech-category-header">
							<Icon icon="trophy" color="var(--accent-regular)" size="1.5rem" gradient />
							<h4>Data & IA</h4>
						</div>
						<div class="tech-pills">
							<span class="tech-pill">Python</span>
							<span class="tech-pill">SQL</span>
							<span class="tech-pill">Pandas</span>
							<span class="tech-pill">Scikit-learn</span>
							<span class="tech-pill">Apache Kafka</span>
							<span class="tech-pill">ETL</span>
						</div>
					</div>
					<div class="tech-category">
						<div class="tech-category-header">
							<Icon icon="rocket-launch" color="var(--accent-regular)" size="1.5rem" gradient />
							<h4>Automatisation IA</h4>
						</div>
						<div class="tech-pills">
							<span class="tech-pill accent">n8n</span>
							<span class="tech-pill accent">Claude API</span>
							<span class="tech-pill accent">Gemini</span>
							<span class="tech-pill accent">Make</span>
							<span class="tech-pill accent">Airtable</span>
							<span class="tech-pill accent">Supabase</span>
						</div>
					</div>
					<div class="tech-category">
						<div class="tech-category-header">
							<Icon icon="terminal-window" color="var(--accent-regular)" size="1.5rem" gradient />
							<h4>Logiciels & Cloud</h4>
						</div>
						<div class="tech-pills">
							<span class="tech-pill">Git</span>
							<span class="tech-pill">Docker</span>
							<span class="tech-pill">PostgreSQL</span>
							<span class="tech-pill">MongoDB</span>
							<span class="tech-pill">REST APIs</span>
						</div>
					</div>
				</div>
			</section>

			<section class="section with-background with-cta">
				<header class="section-header stack gap-2 lg:gap-4">
					<h3>Projets sélectionnés</h3>
					<p>Une sélection de projets en data, software et automatisation IA.</p>
				</header>

				<div class="gallery">
					<Grid variant="offset">
						{projects.map((project) => (
							<li><PortfolioPreview project={project} lang="fr" /></li>
						))}
					</Grid>
				</div>

				<div class="cta">
					<CallToAction href="/fr/work/">
						Voir tout
						<Icon icon="arrow-right" size="1.2em" />
					</CallToAction>
				</div>
			</section>
		</main>

		<ContactCTA title="Intéressé par une collaboration ?" cta="Envoyer un message" />
	</div>
</BaseLayout>

<script>
	function sleep(ms: number) { return new Promise(r => setTimeout(r, ms)); }

	async function typeWriter(el: Element, text: string, speed: number) {
		el.textContent = '';
		for (const char of text) { el.textContent += char; await sleep(speed); }
	}

	async function runHeroAnimation() {
		const title   = document.querySelector('.hero .title') as HTMLElement | null;
		const tagline = document.querySelector('.hero .tagline') as HTMLElement | null;
		const pills   = document.querySelectorAll<HTMLElement>('.roles .pill');
		if (!title || !tagline) return;
		const titleText = title.textContent ?? '';
		const taglineText = tagline.textContent ?? '';
		title.textContent = ''; tagline.textContent = '';
		title.style.minHeight = '1em'; tagline.style.minHeight = '1em';
		pills.forEach(p => { p.style.opacity = '0'; p.style.transform = 'translateY(8px)'; });
		await sleep(300);
		await typeWriter(title, titleText, 55);
		await sleep(150);
		await typeWriter(tagline, taglineText, 25);
		await sleep(200);
		for (const pill of pills) {
			pill.style.transition = 'opacity 0.35s ease, transform 0.35s ease';
			pill.style.opacity = '1'; pill.style.transform = 'translateY(0)';
			await sleep(180);
		}
	}

	document.addEventListener('DOMContentLoaded', runHeroAnimation);

	const cards = document.querySelectorAll<HTMLElement>('.gallery li');
	cards.forEach(card => { card.style.opacity = '0'; card.style.transform = 'translateY(32px)'; card.style.transition = 'none'; });
	const observer = new IntersectionObserver((entries) => {
		entries.forEach(entry => {
			if (entry.isIntersecting) {
				cards.forEach((card, i) => { setTimeout(() => { card.style.transition = 'opacity 0.5s ease, transform 0.5s ease'; card.style.opacity = '1'; card.style.transform = 'translateY(0)'; }, i * 150); });
				observer.disconnect();
			}
		});
	}, { threshold: 0.1 });
	const gallery = document.querySelector('.gallery');
	if (gallery) observer.observe(gallery);
</script>

<style>
	.hero { display: flex; flex-direction: column; align-items: center; gap: 2rem; }
	.hero :global(.title) { font-size: var(--text-2xl); }
	.hero :global(.tagline) { font-size: var(--text-base); white-space: nowrap; }
	.roles { display: none; }
	.hero img { aspect-ratio: 5 / 4; object-fit: cover; object-position: top; border-radius: 1.5rem; box-shadow: var(--shadow-md); }

	@media (min-width: 50em) {
		.hero :global(.title) { font-size: var(--text-3xl); }
		.hero { display: grid; grid-template-columns: 7fr 3fr; padding-inline: 2.5rem; gap: 3.75rem; }
		.roles { margin-top: 0.5rem; display: flex; gap: 0.5rem; flex-wrap: wrap; }
		.hero img { aspect-ratio: 3 / 4; max-height: 320px; border-radius: 3rem; object-fit: cover; align-self: center; }
	}

	.section { display: grid; gap: 2rem; }
	.with-background { position: relative; }
	.with-background::before {
		--hero-bg: var(--bg-image-subtle-2);
		content: ''; position: absolute; pointer-events: none; left: 50%; width: 100vw;
		aspect-ratio: calc(2.25 / var(--bg-scale)); top: 0; transform: translateY(-75%) translateX(-50%);
		background: url('/assets/backgrounds/noise.png') top center/220px repeat, var(--hero-bg) center center / var(--bg-gradient-size) no-repeat, var(--gray-999);
		background-blend-mode: overlay, normal, normal, normal; mix-blend-mode: var(--bg-blend-mode); z-index: -1;
	}
	.section-header { justify-self: center; text-align: center; max-width: 50ch; font-size: var(--text-md); color: var(--gray-300); }
	.section-header h3 { font-size: var(--text-2xl); }

	@media (min-width: 50em) {
		.section { grid-template-columns: repeat(4, 1fr); grid-template-areas: 'header header header header' 'gallery gallery gallery gallery'; gap: 2rem; }
		.section.with-cta { grid-template-areas: 'header header header header' 'cta cta cta cta' 'gallery gallery gallery gallery'; }
		.section-header { grid-area: header; font-size: var(--text-lg); }
		.gallery { grid-area: gallery; }
		.cta { grid-area: cta; display: flex; justify-content: center; }
		.cta :global(a) { padding: 0.25rem 0.75rem; font-size: var(--text-sm); border-radius: 99rem; }
	}

	.tech-stack { display: flex !important; flex-direction: column; align-items: center; gap: 2rem; text-align: center; }
	.tech-grid { display: flex; flex-direction: column; gap: 1.5rem; width: 100%; }
	.tech-category { background: var(--gray-999_40); border: 1px solid var(--gray-800); border-radius: 0.75rem; padding: 1.25rem 1.5rem; text-align: left; }
	.tech-category-header { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.75rem; }
	.tech-category h4 { font-size: var(--text-sm); font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: var(--accent-regular); margin: 0; }
	.tech-pills { display: flex; flex-wrap: wrap; gap: 0.5rem; }
	.tech-pill { font-size: var(--text-sm); padding: 0.25rem 0.75rem; border-radius: 99rem; border: 1px solid var(--gray-700); color: var(--gray-200); background: var(--gray-900); }
	.tech-pill.accent { border-color: var(--accent-regular); color: #ffffff; background: color-mix(in srgb, var(--accent-dark) 40%, transparent); }

	@media (min-width: 50em) {
		.tech-grid { flex-direction: row; }
		.tech-category { flex: 1; border-radius: 1.5rem; padding: 1.5rem 2rem; }
	}
</style>
