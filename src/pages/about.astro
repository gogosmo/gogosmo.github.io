---
import BaseLayout from '../layouts/BaseLayout.astro';

import ContactCTA from '../components/ContactCTA.astro';
import Hero from '../components/Hero.astro';
---

<BaseLayout title="About | Jughurta Gahlouz" description="About Jughurta Gahlouz — Software & Data Engineer based in Paris">
	<div class="stack gap-20">
		<main class="wrapper about">
			<Hero
				title="About Me"
				tagline="Software & Data Engineer passionate about AI, automation, and turning data into real business value."
				align="center"
			/>

			<section>
				<h2 class="section-title">Background</h2>
				<div class="content">
					<p>
						I hold a <a href="https://igm.univ-gustave-eiffel.fr/" target="_blank">Master's degree in Software and Data Engineering</a> from Gustave Eiffel University (IGM, Paris).
						I specialize in backend development, data analysis, and AI automation — driven by a passion for building systems that actually work in production.
					</p>
					<p>
						My journey has taken me through startups and large corporations, which gave me both technical depth and business awareness. Today, I focus on building AI-powered workflows and data solutions that help teams work smarter.
					</p>
					<p>
						Outside of engineering, I explore new automation tools, contribute to open-source projects, and share my learning through GitHub repositories and personal projects.
					</p>
					<p>
						You can find my work and resume <a href="https://github.com/Gogo-IGM-BK" target="_blank">on my GitHub →</a>
					</p>
				</div>
			</section>

			<section>
				<h2 class="section-title">Experience</h2>
				<div class="content experience-list">
					<div class="exp-item">
						<div class="exp-header">
							<span class="exp-role">Software & Data Engineer — Freelance</span>
						</div>
						<p>Building AI automation workflows with n8n, Claude, Gemini, and WhatsApp Business API. Designing data pipelines, Airtable dashboards, and intelligent agents for business clients.</p>
						<div class="exp-tags">
							<span class="exp-tag">n8n</span>
							<span class="exp-tag">Claude API</span>
							<span class="exp-tag">Gemini</span>
							<span class="exp-tag">Python</span>
							<span class="exp-tag">Airtable</span>
							<span class="exp-tag">Supabase</span>
							<span class="exp-tag">WhatsApp API</span>
						</div>
					</div>
					<div class="exp-item">
						<div class="exp-header">
							<span class="exp-role">Data Analyst — Iziwork</span>
						</div>
						<p>ETL processes on NoSQL databases, feasibility studies, and integration of ML model variables to optimize candidate-job matching accuracy and evaluate financial impact of external API usage.</p>
						<div class="exp-tags">
							<span class="exp-tag">Python</span>
							<span class="exp-tag">ETL</span>
							<span class="exp-tag">MongoDB</span>
							<span class="exp-tag">Machine Learning</span>
							<span class="exp-tag">Pandas</span>
							<span class="exp-tag">SQL</span>
						</div>
					</div>
					<div class="exp-item">
						<div class="exp-header">
							<span class="exp-role">IT Project Manager & Developer — McDonald's France</span>
						</div>
						<p>Designed and developed an internal project tracking and management tool, streamlining planning and cross-team synchronization between technical and business stakeholders.</p>
						<div class="exp-tags">
							<span class="exp-tag">JavaScript</span>
							<span class="exp-tag">REST API</span>
							<span class="exp-tag">Agile / Scrum</span>
							<span class="exp-tag">Git</span>
							<span class="exp-tag">Docker</span>
						</div>
					</div>
				</div>
			</section>

			<section>
				<h2 class="section-title">Education</h2>
				<div class="content experience-list">
					<div class="exp-item">
						<div class="exp-header">
							<span class="exp-role">Master 2 — Data & Intelligence Artificielle</span>
							<span class="exp-date">2023 – 2024</span>
						</div>
						<p>Ecole IPSSI, Paris</p>
					</div>
					<div class="exp-item">
						<div class="exp-header">
							<span class="exp-role">Master 2 — Software & Data Engineering</span>
							<span class="exp-date">2021 – 2023</span>
						</div>
						<p>Gustave Eiffel University — Gaspard-Monge Institute (IGM), Paris</p>
					</div>
					<div class="exp-item">
						<div class="exp-header">
							<span class="exp-role">Bachelor — Mathematics & Computer Science</span>
							<span class="exp-date">2017 – 2021</span>
						</div>
						<p>Gustave Eiffel University — Gaspard-Monge Institute (IGM), Paris</p>
					</div>
				</div>
			</section>

			<section>
				<h2 class="section-title">Skills</h2>
				<div class="content skills-grid">
					<div class="skill-group">
						<h5>Languages & Backend</h5>
						<ul>
							<li>Python · Java · JavaScript</li>
							<li>REST API · SQL · NoSQL</li>
							<li>Backend Architecture</li>
						</ul>
					</div>
					<div class="skill-group">
						<h5>Data & AI</h5>
						<ul>
							<li>ETL · Data Analysis</li>
							<li>Machine Learning · Pandas · NumPy</li>
							<li>Data Visualization · Power BI</li>
						</ul>
					</div>
					<div class="skill-group">
						<h5>AI Automation</h5>
						<ul>
							<li>n8n · Make (Integromat)</li>
							<li>Claude · OpenAI · Gemini APIs</li>
							<li>WhatsApp Business · Airtable</li>
						</ul>
					</div>
					<div class="skill-group">
						<h5>Tools & Methods</h5>
						<ul>
							<li>Git · Docker · GitHub Actions</li>
							<li>Agile · Scrum</li>
							<li>Supabase · PostgreSQL · Kafka</li>
						</ul>
					</div>
				</div>
			</section>
		</main>

		<ContactCTA />
	</div>
</BaseLayout>

<style>
	.about :global(.title) {
		font-size: var(--text-xl);
	}

	.about :global(.tagline) {
		font-size: var(--text-sm);
		color: var(--gray-300);
		text-align: center;
	}

	@media (min-width: 50em) {
		.about :global(.title) {
			font-size: var(--text-2xl);
		}
	}

	.about {
		display: flex;
		flex-direction: column;
		gap: 3.5rem;
	}

	img {
		margin-top: 1.5rem;
		border-radius: 1.5rem;
		box-shadow: var(--shadow-md);
	}

	section {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		color: var(--gray-200);
	}

	.section-title {
		grid-column-start: 1;
		font-size: var(--text-xl);
		color: var(--gray-0);
	}

	.content {
		grid-column: 2 / 4;
	}

	.content :global(a) {
		text-decoration: 1px solid underline transparent;
		text-underline-offset: 0.25em;
		transition: text-decoration-color var(--theme-transition);
	}

	.content :global(a:hover),
	.content :global(a:focus) {
		text-decoration-color: currentColor;
	}

	.experience-list {
		display: flex;
		flex-direction: column;
		gap: 2rem;
	}

	.exp-item {
		border-left: 3px solid var(--accent-regular);
		padding-left: 1.25rem;
	}

	.exp-header {
		display: flex;
		flex-wrap: wrap;
		justify-content: space-between;
		align-items: baseline;
		gap: 0.5rem;
		margin-bottom: 0.4rem;
	}

	.exp-role {
		font-weight: 600;
		color: var(--gray-0);
		font-size: var(--text-md);
	}

	.exp-date {
		font-size: var(--text-sm);
		color: var(--accent-regular);
		font-weight: 600;
	}

	.exp-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
		margin-top: 0.6rem;
	}

	.exp-tag {
		font-size: var(--text-xs, 0.75rem);
		padding: 0.2rem 0.6rem;
		border-radius: 99rem;
		border: 1px solid var(--accent-regular);
		color: var(--accent-regular);
		background: color-mix(in srgb, var(--accent-dark) 25%, transparent);
		font-weight: 500;
	}

	.skills-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 2rem;
	}

	.skill-group h5 {
		color: var(--accent-regular);
		margin-bottom: 0.5rem;
		font-size: var(--text-base);
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	.skill-group ul {
		list-style: none;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 0.3rem;
	}

	.skill-group li {
		color: var(--gray-300);
		font-size: var(--text-sm);
	}

	@media (min-width: 50em) {
		.about {
			display: grid;
			grid-template-columns: 1fr 60% 1fr;
		}

		.about > :global(:first-child) {
			grid-column-start: 2;
		}

		section {
			display: contents;
			font-size: var(--text-lg);
		}

		.skills-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}
</style>
